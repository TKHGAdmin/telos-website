{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/api/submit-(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/weekly-summary",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/cron/engagement-check",
      "schedule": "0 15 * * *"
    }
  ]
}
